# TikTok Downloader API
TIKWM_API_BASE=https://www.tikwm.com/api/

# Rate limiting
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# Public shortcut install page URL (marketing landing page)
NEXT_PUBLIC_SHORTCUT_URL=/shortcut

# iCloud Shortcuts share link — enables one-tap "Add Shortcut" on /shortcut
# NEXT_PUBLIC_ICLOUD_SHORTCUT_URL=https://www.icloud.com/shortcuts/xxxxxxxx

# Site URL (set in production for shortcut API examples)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
